OPENAI_API_KEY=
# 可选：默认 gpt-4o-mini（如果你账号不可用可自行改）
OPENAI_MODEL=gpt-4o-mini

# 可选：开启“访问口令/邀请码”保护（建议在公开 demo 时使用）
# - 若设置了 DEMO_PASS，则 /api/ask 必须携带：
#   - header: x-demo-pass: <pass>
#   - 或 body: { "demoPass": "<pass>" }
DEMO_PASS=

# 可选：/api/ask 基础限流（按 IP 的滑动窗口；默认 20 次/60 秒）
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

